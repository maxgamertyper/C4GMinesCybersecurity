{
  "manifest_version": 3,
  "name": "Sushi",
  "description": "phishing detector",
  "version": "1.0",
  "action": {
    "default_popup": "popup/popup.html"
  },
  
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "https://mail.google.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://mail.google.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_end"
    }
  ],

  "icons": {
    "16": "images/icon-16.png",
    "32": "images/icon-32.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  }

}
